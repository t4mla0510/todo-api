# MySQL Database
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/tododb?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=your_username
SPRING_DATASOURCE_PASSWORD=your_password

# JWT
JWT_SECRET=your_secret_key_here
JWT_EXPIRATION=3600000 # 1 hour
JWT_REFRESH_EXPIRATION=604800000 # 7 days

# Server
SERVER_PORT=8080